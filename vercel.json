{
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/recrutement",
      "destination": "/"
    },
    {
      "source": "/((?!sitemap\\.xml$|robots\\.txt$|404\\.html$).*\\.[a-zA-Z]+$)",
      "destination": "/$1"
    }
  ]
}
